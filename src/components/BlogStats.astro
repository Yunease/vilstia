---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

interface Props {
	class?: string;
}
const className = Astro.props.class;

// 核心：统计总文章数（排除指定tag）+ 总字数（包含所有文章）
const calculateBlogStats = async () => {
	// 1. 定义需要排除的标签列表（仅在文章篇数统计中使用）
	const excludeTags = ["mess", "gallery", "photo", "anth"];

	// 2. 获取所有文章（仅排除草稿）
	const [allPosts, allSpecs] = await Promise.all([
		getCollection("posts", ({ data }) => data.draft !== true),
		getCollection("spec", ({ data }) => data.draft !== true),
	]);

	// 合并 posts 和 spec 集合的文章
	const allArticles = [...allPosts, ...allSpecs];

	// 3. 总文章数（排除指定tag的文章）
	const totalPosts = allArticles.filter((post) => {
		const postTags = post.data.tags;
		if (!postTags) return true;
		const tagsArray = Array.isArray(postTags) ? postTags : [postTags];
		const hasExcludeTag = tagsArray.some(
			(tag) => excludeTags.includes(tag.toLowerCase()),
		);
		return !hasExcludeTag;
	}).length;

	// 4. 字数统计函数（完全保留你的逻辑，仅空值兜底，不过滤markdown标签）
	const removeMarkdown = (content: string | undefined) => {
		// 值兜底，避免 undefined 调用 replace
		if (!content) return 0;

		// 新建变量，避免修改原参数
		let cleanedContent = content;
		// 现在文章字数太少了，咱们先把这个过滤删了，等以后字数多了再加上。
		// // 去掉代码块
		// cleanedContent = cleanedContent.replace(/```[\s\S]*?```/g, "");
		// // 去掉行内代码
		// cleanedContent = cleanedContent.replace(/`[^`]+`/g, "");
		// // 去掉 markdown 标题/列表/链接等标签
		// cleanedContent = cleanedContent.replace(/[#*_[\]()<>!|`~]/g, "");
		// // 去掉空行/多余空格
		// cleanedContent = cleanedContent.replace(/\s+/g, " ").trim();
		// 统计纯文本字数
		return cleanedContent.length;
	};

	// 5. 字数统计（统计所有文章，包括被排除tag的文章）
	let totalWords = 0;
	for (const post of allArticles) {
		totalWords += removeMarkdown(post.body);
	}

	// 格式化数字（比如 12345 → 1.2万）
	const formatNumber = (num: number) => {
		if (num >= 10000) {
			return `${(num / 10000).toFixed(1)}万`;
		}
		return num.toString();
	};

	return {
		totalPosts,
		totalWords: formatNumber(totalWords),
	};
};

// 执行统计
const stats = await calculateBlogStats();
---

<!-- 组件渲染部分不变 -->
<div class:list={[className, "card-base p-5 rounded-lg onload-animation"]} style="animation-delay: 300ms">
  <h3 class="font-bold text-lg mb-4 flex items-center text-[var(--primary)]">
    <Icon name="material-symbols:analytics" class="mr-2 text-xl" />
    博客总览
  </h3>
  <div class="grid grid-cols-2 gap-4">
    <div class="flex flex-col items-center justify-center p-3 bg-gray-50 dark:bg-gray-800/50 rounded-lg">
      <Icon name="material-symbols:article" class="text-[var(--primary)] text-2xl mb-1" />
      <span class="text-sm text-neutral-700 dark:text-neutral-300">总文章</span>
      <span class="text-xl font-bold text-[var(--primary)]">{stats.totalPosts} 篇</span>
    </div>
    <div class="flex flex-col items-center justify-center p-3 bg-gray-50 dark:bg-gray-800/50 rounded-lg">
      <Icon name="material-symbols:format-size" class="text-[var(--primary)] text-2xl mb-1" />
      <span class="text-sm text-neutral-700 dark:text-neutral-300">总字数</span>
      <span class="text-xl font-bold text-[var(--primary)]">{stats.totalWords}</span>
    </div>
  </div>
</div>