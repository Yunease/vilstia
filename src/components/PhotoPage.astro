---
import type { PhotoAlbum } from "../utils/photo-utils";
import AlbumCard from "./AlbumCard.astro";

interface Props {
	albums: PhotoAlbum[];
}

const { albums } = Astro.props;

const len = albums.length;
let delay = 0;
const interval = 80;
---

<div class="flex flex-col">
	<!-- Page Title and Description -->
	<div class="card-base p-6 mb-8 onload-animation">
		<h1 class="text-3xl font-bold text-[var(--primary)] mb-3">截光求影</h1>
		<p class="text-[var(--text-neutral)] dark:text-white/80 leading-relaxed">
			捕捉光影的瞬间，定格时间的流逝。
		</p>
		<p class="text-[var(--text-neutral)] dark:text-white/80 leading-relaxed">
			每一次快门都是与世界的一次对话，每一张照片都是故事的开端。
		</p>
		<p class="text-[var(--text-neutral)] dark:text-white/80 leading-relaxed">
			&nbsp;
		</p>
		<p class="text-[var(--text-neutral)] dark:text-white/80 leading-relaxed">
			在镜头中寻找被忽略的美好。
		</p>
	</div>

	<!-- Album Grid -->
	<div class="album-grid mb-4">
		{albums.map((album) => (
			<AlbumCard
				name={album.name}
				coverImage={album.coverImage}
				count={album.count}
				latestDate={album.latestDate}
				class="onload-animation"
				style={`animation-delay: calc(var(--content-delay) + ${delay++ * interval}ms);`}
			/>
		))}
	</div>
</div>

<style>
	.album-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
	}

	@media (min-width: 480px) {
		.album-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 1.75rem;
		}
	}

	@media (min-width: 768px) {
		.album-grid {
			grid-template-columns: repeat(3, 1fr);
			gap: 2rem;
		}
	}

	@media (min-width: 1024px) {
		.album-grid {
			grid-template-columns: repeat(3, 1fr);
			gap: 2.25rem;
		}
	}

	@media (min-width: 1280px) {
		.album-grid {
			grid-template-columns: repeat(4, 1fr);
			gap: 2.5rem;
		}
	}
</style>
