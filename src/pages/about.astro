---

import { getCollection } from "astro:content";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const aboutPosts = await getCollection("spec", ({ id }) => id.startsWith("about"));

// 按日期排序，最新的在前面
const sortedPosts = aboutPosts.sort((a, b) =>
	b.data.published.valueOf() - a.data.published.valueOf()
);

// 格式化日期
function formatDate(date: Date): string {
	return date.toLocaleDateString("zh-CN", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}

// 获取 slug（处理 about.md 和 about/xxx.md 的情况）
function getSlug(id: string): string {
	const slug = id
		.replace("about", "")
		.replace(/^\//, "")
		.replace(/\.md$/, "");
	return slug || "default";
}
---

<MainGridLayout title={i18n(I18nKey.about)} description={i18n(I18nKey.about)}>
	<div class="about-list-wrapper">
		<div class="card-base z-10 px-6 py-4 relative w-full rounded-[var(--radius-large)]">
			<ul class="about-list">
				{
					sortedPosts.map((post, index) => (
						<li class="about-item-group group" data-index={index}>
							<a
								href={`/about/${getSlug(post.id)}/`}
								class="about-item"
								style={`--animation-delay: ${index * 50}ms`}
							>
								<span class="about-date">{formatDate(post.data.published)}</span>
								<span class="about-title">{post.data.title}</span>
								<span class="about-arrow">→</span>
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</MainGridLayout>

<style>
	.about-list-wrapper {
		animation: fade-in-up 300ms ease-out;
		animation-fill-mode: forwards;
	}

	.about-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.about-item-group {
		position: relative;
		padding: 0 0.75rem;
	}

	.about-item {
		display: flex;
		align-items: center;
		padding: 1.125rem 0.75rem;
		text-decoration: none;
		color: inherit;
		border-radius: 0.5rem;
		transition: background-color 200ms ease, transform 200ms ease;
		animation: fade-in-up 300ms ease-out backwards;
		animation-delay: var(--animation-delay);
	}

	.about-item:hover {
		background-color: var(--btn-plain-bg-hover);
		transform: translateX(4px);
	}

	.about-item:active {
		background-color: var(--btn-plain-bg-active);
		transform: translateX(2px);
	}

	.about-date {
		flex-shrink: 0;
		font-size: 1em;
		font-weight: 700;
		color: var(--meta-text);
		min-width: 120px;
	}

	.about-title {
		flex: 1;
		font-weight: 400;
		color: var(--title-text);
	}

	.about-arrow {
		flex-shrink: 0;
		opacity: 0;
		transform: translateX(-8px);
		transition: opacity 200ms ease, transform 200ms ease;
		color: var(--primary);
	}

	.about-item:hover .about-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	@keyframes fade-in-up {
		0% {
			transform: translateY(1rem);
			opacity: 0;
		}
		100% {
			transform: translateY(0);
			opacity: 1;
		}
	}

	/* 移动端适配 */
	@media (max-width: 640px) {
		.about-item-group {
			padding: 0 0.5rem;
		}

		.about-item {
			padding: 1rem 0.5rem;
		}

		.about-date {
			min-width: 90px;
			font-size: 0.9em;
		}

		.about-title {
			font-size: 0.95em;
		}

		.about-divider {
			padding: 0 0.5rem;
		}
	}
</style>
