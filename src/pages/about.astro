---

import { getCollection } from "astro:content";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

const aboutPosts = await getCollection("spec", ({ id }) =>
	id.startsWith("about"),
);

// 按 tag 分组
const groups: Record<string, typeof aboutPosts> = { me: [], like: [], oc: [] };
for (const post of aboutPosts) {
	const tag = post.data.tag;
	if (tag === "me") groups.me.push(post);
	else if (tag === "like") groups.like.push(post);
	else groups.oc.push(post);
}

// 每组内 star 置顶，其余按日期降序
for (const key of Object.keys(groups)) {
	groups[key].sort((a, b) => {
		const aStar = a.data.category === "star" ? 1 : 0;
		const bStar = b.data.category === "star" ? 1 : 0;
		if (aStar !== bStar) return bStar - aStar;
		return b.data.published.valueOf() - a.data.published.valueOf();
	});
}

const sectionOrder: { key: string; title: string }[] = [
	{ key: "me", title: "关于我" },
	{ key: "like", title: "品味" },
	{ key: "oc", title: "关于我的oc" },
];

// 格式化日期
function formatDate(date: Date): string {
	return date.toLocaleDateString("zh-CN", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}

// 获取 slug
function getSlug(id: string): string {
	const slug = id.replace("about", "").replace(/^\//, "").replace(/\.md$/, "");
	return slug || "default";
}
---

<MainGridLayout title={i18n(I18nKey.about)} description={i18n(I18nKey.about)}>
	<div class="card-base z-10 px-0 relative w-full overflow-hidden">
	<div class="about-wrapper">
		{sectionOrder.map((section, si) => {
			const posts = groups[section.key];
			if (posts.length === 0) return null;
			const isLast = si === sectionOrder.length - 1 || sectionOrder.slice(si + 1).every(s => groups[s.key].length === 0);
			return (
				<div class={`about-section ${!isLast ? "about-section-divided" : ""}`} style={`--section-delay: ${si * 100}ms`}>
					<div class="about-section-header">
						<span class="about-section-dot" />
						<h2 class="about-section-title">{section.title}</h2>
						<span class="about-section-count">{posts.length}</span>
					</div>
					<div class="about-section-cards">
						{posts.map((post, index) => (
							<a
								href={`/about/${getSlug(post.id)}/`}
								class={`about-card group${post.data.category === "star" ? " about-card-star-item" : ""}`}
								style={`--card-delay: calc(var(--section-delay) + ${index * 60}ms)`}
							>
								<span class="about-card-accent" />
								<span class="about-card-date">{formatDate(post.data.published)}</span>
								<span class="about-card-title">{post.data.title}</span>
								{post.data.category === "star" && <span class="about-card-star">★</span>}
								<span class="about-card-arrow">→</span>
							</a>
						))}
					</div>
				</div>
			);
		})}
	</div>
	</div>
</MainGridLayout>

<style>
	.about-wrapper {
		animation: fade-in-up 300ms ease-out;
		animation-fill-mode: forwards;
	}

	/* === 分区 === */
	.about-section {
		padding: 1.25rem 1.5rem;
		animation: fade-in-up 400ms ease-out backwards;
		animation-delay: var(--section-delay);
	}

	.about-section-divided {
		border-bottom: 1px solid oklch(0.85 0.01 var(--hue));
	}

	:global(.dark) .about-section-divided {
		border-bottom-color: oklch(0.3 0.01 var(--hue));
	}

	/* 分区标题行 */
	.about-section-header {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 0.75rem;
	}

	.about-section-dot {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		background: var(--primary);
		flex-shrink: 0;
	}

	.about-section-title {
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--primary);
		margin: 0;
		letter-spacing: 0.02em;
	}

	.about-section-count {
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--primary);
		background: oklch(0.94 0.02 var(--hue));
		border-radius: 9999px;
		padding: 0.1rem 0.5rem;
		line-height: 1.4;
	}

	:global(.dark) .about-section-count {
		background: oklch(0.3 0.03 var(--hue));
	}

	/* === 卡片 === */
	.about-section-cards {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.about-card {
		position: relative;
		display: flex;
		align-items: center;
		padding: 0.85rem 0.75rem;
		gap: 0.75rem;
		text-decoration: none;
		color: inherit;
		border-radius: 0.375rem;
		transition: background-color 150ms ease, transform 150ms ease;
		animation: fade-in-up 400ms ease-out backwards;
		animation-delay: var(--card-delay);
	}

	.about-card:hover {
		background-color: var(--btn-plain-bg-hover);
		transform: translateX(3px);
	}

	.about-card:active {
		background-color: var(--btn-plain-bg-active);
	}

	/* star 置顶项突出显示 */
	.about-card-star-item {
		padding: 1.15rem 1rem;
		margin-bottom: 4px;
		background: oklch(0.97 0.01 var(--hue));
		border-radius: 0.5rem;
	}

	:global(.dark) .about-card-star-item {
		background: oklch(0.22 0.015 var(--hue));
	}

	.about-card-star-item .about-card-date {
		font-size: 1em;
		min-width: 120px;
	}

	.about-card-star-item .about-card-title {
		font-size: 1.15em;
		font-weight: 600;
	}

	/* 左侧竖线装饰 */
	.about-card-accent {
		position: absolute;
		left: 0;
		top: 25%;
		height: 50%;
		width: 3px;
		border-radius: 3px;
		background: var(--primary);
		opacity: 0;
		transform: scaleY(0.5);
		transition: opacity 200ms ease, transform 200ms ease;
	}

	.about-card:hover .about-card-accent {
		opacity: 1;
		transform: scaleY(1);
	}

	.about-card-date {
		flex-shrink: 0;
		font-size: 0.9em;
		font-weight: 600;
		color: oklch(0.55 0.02 var(--hue));
		min-width: 110px;
	}

	:global(.dark) .about-card-date {
		color: oklch(0.6 0.02 var(--hue));
	}

	.about-card-title {
		flex: 1;
		font-weight: 500;
		color: var(--title-text, inherit);
	}

	.about-card-star {
		color: oklch(0.75 0.14 85);
		font-size: 0.85em;
		flex-shrink: 0;
	}

	.about-card-arrow {
		flex-shrink: 0;
		opacity: 0;
		transform: translateX(-6px);
		transition: opacity 200ms ease, transform 200ms ease;
		color: var(--primary);
		font-size: 0.85em;
		font-weight: 600;
	}

	.about-card:hover .about-card-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	@keyframes fade-in-up {
		0% {
			transform: translateY(0.75rem);
			opacity: 0;
		}
		100% {
			transform: translateY(0);
			opacity: 1;
		}
	}

	/* 移动端适配 */
	@media (max-width: 640px) {
		.about-section {
			padding: 1rem 1rem;
		}

		.about-card {
			padding: 0.75rem 0.5rem;
			gap: 0.5rem;
		}

		.about-card-date {
			min-width: 85px;
			font-size: 0.85em;
		}

		.about-card-title {
			font-size: 0.95em;
		}
	}
</style>
