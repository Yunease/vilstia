---
import { Icon } from "astro-icon/components";
import { friendsConfig } from "../config";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

// 处理 URL，确保外链正确添加 https:// 前缀
function processUrl(url: string): string {
    if (!url) return "#";
    if (url.startsWith("http://") || url.startsWith("https://")) {
        return url;
    }
    return "https://" + url;
}
---

<MainGridLayout title={i18n(I18nKey.friends)} description={i18n(I18nKey.friends)}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-6 py-5 relative w-full ">
            <div class="flex flex-col gap-10">
                {friendsConfig.map((friend) => (
                    <a
                        href={processUrl(friend.url)}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="friend-card group block relative"
                    >
                        <!-- 卡片主体 - 垂直布局: 头像在左，名字+签名在右 -->
                        <div class="friend-card-inner relative flex items-center p-4 rounded-[var(--radius-large)] bg-[var(--card-bg)] transition-all duration-300 hover:bg-[var(--btn-plain-bg-hover)]">
                            <!-- 头像 - 方形圆角，约120px -->
                            <div class="friend-avatar-wrapper relative w-30 h-[120px] flex-shrink-0 mr-4 rounded-xl overflow-hidden">
                                <div class="friend-avatar w-full h-full">
                                    <img
                                        src={friend.avatar}
                                        alt={friend.name}
                                        class="w-full h-full object-cover"
                                    />
                                </div>
                                <!-- 悬停遮罩 -->
                                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 flex items-center justify-center transition-all duration-300">
                                    <Icon name="fa6-solid:arrow-up-right-from-square" class="text-white text-2xl opacity-0 group-hover:opacity-100 scale-75 group-hover:scale-100 transition-all duration-300 drop-shadow-md" />
                                </div>
                            </div>

                            <!-- 右侧信息 -->
                            <div class="flex flex-col justify-center flex-1 min-w-0">
                                <!-- 朋友名字 -->
                                <h3 class="text-xl font-bold text-[var(--primary)] truncate group-hover:underline decoration-2 underline-offset-2 transition-all duration-300 -mt-3 ml-2.5">
                                    {friend.name}
                                </h3>
                                <!-- 个人签名 -->
                                {friend.bio && (
                                    <p class="text-sm text-neutral-700 dark:text-neutral-300 truncate mt-4 ml-6">
                                        {friend.bio}
                                    </p>
                                )}
                            </div>
                        </div>
                    </a>
                ))}
            </div>
            {friendsConfig.length === 0 && (
                <p class="text-center text-neutral-700 dark:text-neutral-300 py-8">
                    暂无友链
                </p>
            )}
        </div>
    </div>
</MainGridLayout>

<style>
    /* 3D 悬停效果 */
    .friend-card {
        perspective: 1000px;
    }

    .friend-card-inner {
        transform-style: preserve-3d;
        transform: translateZ(0);
    }

    .friend-card:hover .friend-card-inner {
        /* 3D上浮效果 */
        transform: translateY(-4px) translateZ(20px) scale(1.02);
        box-shadow:
            0 12px 24px rgba(0, 0, 0, 0.15),
            0 0 0 2px var(--primary),
            inset 0 0 30px rgba(var(--primary), 0.05);
    }

    /* 头像 3D 悬停动画 */
    .friend-avatar {
        transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                    box-shadow 0.4s ease;
    }

    .friend-card:hover .friend-avatar {
        /* 放大 + 向左倾斜的 3D 效果 */
        transform: scale(1.15) rotateY(-12deg) rotateX(5deg);
        /* 底部使用全局 primary 配色的阴影 */
        box-shadow:
            0 15px 35px -5px var(--primary),
            0 8px 20px -3px var(--primary);
    }

    /* 名字悬停发光效果 */
    .friend-card:hover h3 {
        text-shadow: 0 0 10px var(--primary);
    }
</style>
