---
import MainGridLayout from "@layouts/MainGridLayout.astro";

// 年度记录列表（从 2025 年开始）
const years = [
	{ year: 2025, path: "/memory/2025/" },
];
---

<MainGridLayout title="年度记录" description="我的博客网站与年度记录，从 2025 年开始">
	<div class="flex flex-col">
		<!-- 标题说明 -->
		<div class="card-base p-6 mb-8 onload-animation">
			<h1 class="text-3xl font-bold text-[var(--primary)] mb-3">年度记录</h1>
			<p class="text-neutral-700 dark:text-neutral-300 leading-relaxed">
				这里记录了我每一年的博客站点变迁与个人成长，从 2025 年开始。
			</p>
		</div>

		<!-- 年份列表 -->
		<div class="transition flex flex-col rounded-[var(--radius-large)] bg-[var(--card-bg)] py-1 md:py-0 md:bg-transparent md:gap-4 mb-4">
			{years.map((item) => (
				<a href={item.path}
				   class="card-base flex items-center gap-3 p-5 onload-animation
						  hover:bg-[var(--btn-card-bg-hover)] transition-colors cursor-pointer">
					<span class="text-lg font-bold text-[var(--primary)] flex-shrink-0">
						{item.year}
					</span>
					<span class="text-neutral-400 flex-shrink-0">—</span>
					<span class="text-sm text-neutral-700 dark:text-neutral-300">
						至今
					</span>
				</a>
			))}
		</div>
	</div>
</MainGridLayout>
