{
	"headers": [
		{
			"source": "/_astro/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "no-cache"
				}
			]
		}
	],
	"routes": [
		{ "handle": "filesystem" },
		{ "src": "/(.*)", "status": 404, "dest": "/" }
	]
}
